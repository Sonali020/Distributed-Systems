import java.util.Scanner;

class Ring {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        System.out.print("Enter number of processes: ");
        int n = sc.nextInt();

        System.out.print("Enter failed process ID: ");
        int failed = sc.nextInt();

        int leader = 0;

        System.out.println("Active Processes:");

        for (int i = 1; i <= n; i++) {
            if (i != failed) {
                System.out.println("Process " + i + " is active");
                leader = i; // highest active ID becomes leader
            }
        }

        System.out.println("Process " + leader + " elected as Leader");

        sc.close();
    }
}
